# .htaccess - Ottimizzazioni SEO e Performance per Blog Favignana

# ===== 1. REWRITE RULES (URL Friendly) =====
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Rimuovi www (opzionale, mantieni coerenza)
    # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    # RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    # HTTPS forzato
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Rimuovi .html dall'URL (optional)
    # RewriteCond %{REQUEST_FILENAME} !-f
    # RewriteCond %{REQUEST_FILENAME} !-d
    # RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>

# ===== 2. CACHE CONTROL =====
# Abilita cache del browser per ridurre traffico
<IfModule mod_expires.c>
    ExpiresActive On

    # Immagini: 30 giorni
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"

    # CSS e JavaScript: 7 giorni
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"

    # HTML: 1 giorno (cambio frequente)
    ExpiresByType text/html "access plus 1 day"

    # Font: 30 giorni
    ExpiresByType font/ttf "access plus 30 days"
    ExpiresByType font/otf "access plus 30 days"
    ExpiresByType font/woff "access plus 30 days"
    ExpiresByType font/woff2 "access plus 30 days"
</IfModule>

# ===== 3. COMPRESSION (Gzip) =====
# Comprimi file per ridurre bandwidthе
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE text/javascript
</IfModule>

# ===== 4. SICUREZZA =====
# Proibisci accesso a file sensibili
<Files "robots.txt">
    Allow from all
</Files>

<Files "sitemap.xml">
    Allow from all
</Files>

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Disabilita directory listing
Options -Indexes

# ===== 5. PERFORMANCE HEADERS =====
<IfModule mod_headers.c>
    # Cache-Control
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|otf)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>

    # Pagine HTML
    <FilesMatch "\.html$">
        Header set Cache-Control "max-age=86400, public"
    </FilesMatch>

    # Sitemap e RSS
    <FilesMatch "\.(xml|rss)$">
        Header set Cache-Control "max-age=3600, public"
    </FilesMatch>

    # Security Headers
    Header set X-UA-Compatible "IE=edge"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ===== 6. SEO FRIENDLY =====
# 404 Error Page (crea un file 404.html per migliore UX)
# ErrorDocument 404 /404.html

# Reindirizza URL con doppio slash
<IfModule mod_rewrite.c>
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ //
    RewriteRule ^(.*)$ /$1 [R=301,L]
</IfModule>

# ===== 7. DISABILITA HOT LINKING =====
# Proibisci a siti esterni di usare le tue immagini
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?ilmiosud\.it [NC]
    RewriteRule \.(jpg|jpeg|png|gif|svg)$ - [F]
</IfModule>

# ===== NOTE =====
# Se il server non supporta mod_rewrite, alcune regole non funzioneranno
# Verifica con l'hosting se Apache è configurato con mod_rewrite abilitato